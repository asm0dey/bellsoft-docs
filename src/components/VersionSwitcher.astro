---
import Default from '@astrojs/starlight/components/Sidebar.astro';
import { Icon } from '@astrojs/starlight/components';
// Real BellSoft product logos for the switcher. The starlight-sidebar-topics
// plugin only renders built-in icon names, so we render the topic list
// ourselves (reading its locals) to use the real logos.
import logoJdk from '../assets/logo-liberica-jdk.svg?url';
import logoNik from '../assets/logo-nik.svg?url';
import logoAlpaquita from '../assets/logo-alpaquita.svg?url';
import {
  PRODUCT_VERSIONS,
  productOf,
  versionOf,
  defaultVersionOf,
  filterSidebarForVersion,
  stripBase,
} from '../lib/swapVersion.mjs';

// Map each product topic to its real logo; Container Images has none and
// falls back to its built-in icon.
const TOPIC_LOGOS = {
  'Liberica JDK': logoJdk,
  'Native Image Kit': logoNik,
  'Alpaquita Linux': logoAlpaquita,
};
const { topics } = Astro.locals.starlightSidebarTopics;

// Astro.url.pathname includes the configured base — strip it so the version
// logic sees base-relative paths. data-path is stored stripped too.
const pathname = stripBase(Astro.url.pathname, import.meta.env.BASE_URL);
const active = versionOf(pathname);
const product = productOf(pathname);

// On a version page the dropdown reflects the active version; on a shared/
// landing page it reflects the version whose group the sidebar shows (latest).
const displaySlug = product ? active ?? defaultVersionOf(product) : null;
const versions = product ? PRODUCT_VERSIONS[product] : [];
const currentLabel = versions.find((v) => v.slug === displaySlug)?.label ?? '';

// Show only that one version's group in the sidebar.
const route = Astro.locals.starlightRoute;
if (product && active) {
  route.sidebar = filterSidebarForVersion(route.sidebar, product, active);
}
---

<nav class="product-switcher" aria-label="Products">
  <ul>
    {
      topics.map((topic) => (
        <li>
          <a
            href={topic.link}
            class:list={['product-link', { current: topic.isCurrent }]}
          >
            <span class="product-logo">
              {TOPIC_LOGOS[topic.label] ? (
                <img src={TOPIC_LOGOS[topic.label]} alt="" width="24" height="24" />
              ) : (
                topic.icon && <Icon name={topic.icon} size="1.25rem" />
              )}
            </span>
            <span>{topic.label}</span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

{
  displaySlug && (
    <div class="version-picker" data-path={pathname} data-product={product}>
      <span class="version-picker-label">Version</span>
      <button type="button" class="version-current" aria-haspopup="listbox" aria-expanded="false">
        <span class="version-current-label">{currentLabel}</span>
        <Icon name="down-caret" size="1rem" />
      </button>
      <div class="version-panel" hidden>
        <input
          type="text"
          class="version-search"
          placeholder="Search version…"
          autocomplete="off"
          spellcheck="false"
          aria-label="Search version"
        />
        <ul class="version-list" role="listbox">
          {versions.map((v) => (
            <li
              role="option"
              class:list={['version-option', { selected: v.slug === displaySlug }]}
              data-slug={v.slug}
              data-label={v.label}
              aria-selected={v.slug === displaySlug}
            >
              {v.label}
            </li>
          ))}
        </ul>
        <p class="version-empty" hidden>No matching version</p>
      </div>
    </div>
  )
}

<Default><slot /></Default>

<script>
  import {
    swapVersion, stripBase, withBase, versionOf, defaultVersionOf,
    resolveActiveVersion, versionSlugForGroupLabel, versionPagePath,
  } from '../lib/swapVersion.mjs';

  const BASE = import.meta.env.BASE_URL;
  const picker = document.querySelector('.version-picker');

  const storeKey = (product) => `bellsoft:v:${product}`;
  const getStored = (product) => {
    try { return localStorage.getItem(storeKey(product)); } catch { return null; }
  };
  const setStored = (product, slug) => {
    try { localStorage.setItem(storeKey(product), slug); } catch {}
  };

  // Point common-page body links (<VersionLink>) at the active version.
  function rewriteVlinks(product, slug) {
    for (const a of document.querySelectorAll('a[data-vlink]')) {
      if (a.dataset.vproduct && a.dataset.vproduct !== product) continue;
      a.setAttribute('href', withBase(versionPagePath(product, slug, a.dataset.vlink), BASE));
    }
  }

  // On a common page the sidebar holds every version group; show only the active.
  function showVersionGroup(product, slug) {
    const groups = document.querySelectorAll('#starlight__sidebar .top-level > li');
    for (const li of groups) {
      const summary = li.querySelector(':scope > details > summary');
      if (!summary) continue;
      const groupSlug = versionSlugForGroupLabel(product, summary.textContent.trim());
      if (!groupSlug) continue; // not a version group — leave visible
      li.hidden = groupSlug !== slug;
    }
  }

  // Starlight stamps aria-current on only ONE of the duplicate sidebar links for
  // a common page (the latest group's copy). When another version's group is the
  // visible one, that marker is in a hidden group — move it to the visible copy.
  function markCurrent() {
    const here = location.pathname.replace(/\/+$/, '');
    for (const a of document.querySelectorAll('#starlight__sidebar a[href]')) {
      if (a.getAttribute('href').replace(/\/+$/, '') !== here) continue;
      const li = a.closest('.top-level > li');
      if (li && li.hidden) a.removeAttribute('aria-current');
      else a.setAttribute('aria-current', 'page');
    }
  }

  if (picker instanceof HTMLElement) {
    const product = picker.dataset.product ?? '';
    const fromPath = picker.dataset.path ?? stripBase(location.pathname, BASE);
    const onVersionPage = Boolean(versionOf(fromPath));

    const button = picker.querySelector('.version-current');
    const panel = picker.querySelector('.version-panel');
    const search = picker.querySelector('.version-search');
    const list = picker.querySelector('.version-list');
    const empty = picker.querySelector('.version-empty');
    const options = Array.from(picker.querySelectorAll('.version-option'));

    const setOpen = (open) => {
      panel.hidden = !open;
      button.setAttribute('aria-expanded', String(open));
      if (open) { search.value = ''; filter(''); search.focus(); }
    };
    const filter = (q) => {
      const needle = q.trim().toLowerCase();
      let shown = 0;
      for (const li of options) {
        const match = li.dataset.label.toLowerCase().includes(needle);
        li.hidden = !match;
        if (match) shown++;
      }
      empty.hidden = shown > 0;
    };

    // Common page: reflect a chosen version without navigating.
    const applyCommonVersion = (slug) => {
      setStored(product, slug);
      showVersionGroup(product, slug);
      markCurrent();
      rewriteVlinks(product, slug);
      const label = options.find((li) => li.dataset.slug === slug)?.dataset.label ?? '';
      const cur = picker.querySelector('.version-current-label');
      if (cur) cur.textContent = label;
      for (const li of options) {
        const on = li.dataset.slug === slug;
        li.classList.toggle('selected', on);
        li.setAttribute('aria-selected', String(on));
      }
    };

    const navigate = (slug) => {
      if (onVersionPage) {
        location.pathname = withBase(swapVersion(fromPath, slug), BASE);
      } else {
        applyCommonVersion(slug);
        setOpen(false);
      }
    };

    button.addEventListener('click', () => setOpen(panel.hidden));
    search.addEventListener('input', () => filter(search.value));
    list.addEventListener('click', (event) => {
      const li = event.target.closest('.version-option');
      if (li) navigate(li.dataset.slug);
    });
    search.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        const first = options.find((li) => !li.hidden);
        if (first) navigate(first.dataset.slug);
      } else if (event.key === 'Escape') {
        setOpen(false); button.focus();
      }
    });
    document.addEventListener('click', (event) => {
      if (!picker.contains(event.target)) setOpen(false);
    });

    // Initial state: persist the URL's version (version page) or reflect the
    // reader's stored choice (common page).
    if (onVersionPage) {
      setStored(product, versionOf(fromPath));
    } else {
      applyCommonVersion(resolveActiveVersion(product, fromPath, getStored(product)));
    }
  }
</script>

<style>
  .product-switcher {
    margin-bottom: 1rem;
  }
  .product-switcher ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .product-link {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.4rem 0.5rem;
    border-radius: 0.5rem;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    font-size: var(--sl-text-sm);
    line-height: 1.2;
  }
  .product-link:hover {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
  }
  .product-link.current {
    background: var(--sl-color-accent-low);
    color: var(--sl-color-white);
    font-weight: 600;
  }
  .product-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
  }
  .product-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .version-picker {
    position: relative;
    padding: 0.75rem 0;
    margin-bottom: 0.5rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
  }
  .version-picker-label {
    display: block;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }
  .version-current {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    width: 100%;
    padding: 0.4rem 0.5rem;
    border-radius: 0.5rem;
    background: var(--sl-color-black);
    color: var(--sl-color-white);
    border: 1px solid var(--sl-color-gray-5);
    font-size: var(--sl-text-sm);
    cursor: pointer;
  }
  .version-current:hover,
  .version-current[aria-expanded='true'] {
    border-color: var(--sl-color-accent);
  }
  .version-panel {
    position: absolute;
    z-index: 20;
    left: 0;
    right: 0;
    margin-top: 0.25rem;
    padding: 0.4rem;
    background: var(--sl-color-black);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);
  }
  .version-panel[hidden] {
    display: none;
  }
  .version-search {
    width: 100%;
    box-sizing: border-box;
    padding: 0.35rem 0.5rem;
    margin-bottom: 0.4rem;
    border-radius: 0.375rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    border: 1px solid var(--sl-color-gray-5);
    font-size: var(--sl-text-sm);
  }
  .version-search:focus {
    outline: none;
    border-color: var(--sl-color-accent);
  }
  .version-list {
    list-style: none;
    margin: 0;
    padding: 0;
    max-height: 14rem;
    overflow-y: auto;
  }
  .version-option {
    padding: 0.35rem 0.5rem;
    border-radius: 0.375rem;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-2);
    cursor: pointer;
  }
  .version-option:hover {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
  }
  .version-option.selected {
    color: var(--sl-color-white);
    font-weight: 600;
  }
  .version-option[hidden] {
    display: none;
  }
  .version-empty {
    margin: 0;
    padding: 0.35rem 0.5rem;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-4);
  }
  .version-empty[hidden] {
    display: none;
  }
</style>
