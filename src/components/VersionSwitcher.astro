---
import Default from '@astrojs/starlight/components/Sidebar.astro';
import Search from '@astrojs/starlight/components/Search.astro';
import { Icon } from '@astrojs/starlight/components';
// Real BellSoft product logos for the switcher. The starlight-sidebar-topics
// plugin only renders built-in icon names, so we render the topic list
// ourselves (reading its locals) to use the real logos.
import logoJdk from '../assets/logo-liberica-jdk.svg?url';
import logoNik from '../assets/logo-nik.svg?url';
import logoAlpaquita from '../assets/logo-alpaquita.svg?url';
import {
  PRODUCT_VERSIONS,
  productOf,
  versionOf,
  defaultVersionOf,
  filterSidebarForVersion,
} from '../lib/swapVersion.mjs';

// Map each product topic to its real logo; Container Images has none and
// falls back to its built-in icon.
const TOPIC_LOGOS = {
  'Liberica JDK': logoJdk,
  'Native Image Kit': logoNik,
  'Alpaquita Linux': logoAlpaquita,
};
const { topics } = Astro.locals.starlightSidebarTopics;

const pathname = Astro.url.pathname;
const active = versionOf(pathname);
const product = productOf(pathname);

// On a version page the dropdown reflects the active version; on a shared/
// landing page it reflects the version whose group the sidebar shows (latest).
const displaySlug = product ? active ?? defaultVersionOf(product) : null;
const versions = product ? PRODUCT_VERSIONS[product] : [];

// Show only that one version's group in the sidebar.
const route = Astro.locals.starlightRoute;
if (product && displaySlug) {
  route.sidebar = filterSidebarForVersion(route.sidebar, product, displaySlug);
}
---

<div class="sidebar-search">
  <Search />
</div>

<nav class="product-switcher" aria-label="Products">
  <ul>
    {
      topics.map((topic) => (
        <li>
          <a
            href={topic.link}
            class:list={['product-link', { current: topic.isCurrent }]}
          >
            <span class="product-logo">
              {TOPIC_LOGOS[topic.label] ? (
                <img src={TOPIC_LOGOS[topic.label]} alt="" width="24" height="24" />
              ) : (
                topic.icon && <Icon name={topic.icon} size="1.25rem" />
              )}
            </span>
            <span>{topic.label}</span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

{
  product && (
    <div class="version-switcher">
      <label for="version-select">Version</label>
      <select id="version-select" data-path={pathname} data-product={product}>
        {versions.map((v) => (
          <option value={v.slug} selected={v.slug === displaySlug}>
            {v.label}
          </option>
        ))}
      </select>
    </div>
  )
}

<Default><slot /></Default>

<script>
  import { swapVersion } from '../lib/swapVersion.mjs';
  const select = document.getElementById('version-select');
  if (select instanceof HTMLSelectElement) {
    select.addEventListener('change', () => {
      const from = select.dataset.path ?? location.pathname;
      const product = select.dataset.product ?? '';
      const swapped = swapVersion(from, select.value);
      // On a version page swapVersion changes the path (same page, new version).
      // On a shared/landing page it returns unchanged, so enter that version
      // at its install guide.
      location.pathname =
        swapped !== from ? swapped : `/${product}/${select.value}/install-guide/`;
    });
  }
</script>

<style>
  .sidebar-search {
    margin-bottom: 1rem;
  }
  .product-switcher {
    margin-bottom: 1rem;
  }
  .product-switcher ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .product-link {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.4rem 0.5rem;
    border-radius: 0.5rem;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    font-size: var(--sl-text-sm);
    line-height: 1.2;
  }
  .product-link:hover {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
  }
  .product-link.current {
    background: var(--sl-color-accent-low);
    color: var(--sl-color-white);
    font-weight: 600;
  }
  .product-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
  }
  .product-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .version-switcher {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem 0;
    margin-bottom: 0.5rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
  }
  .version-switcher label {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .version-switcher select {
    padding: 0.4rem 0.5rem;
    border-radius: 0.5rem;
    background: var(--sl-color-black);
    color: var(--sl-color-white);
    border: 1px solid var(--sl-color-gray-5);
    font-size: var(--sl-text-sm);
  }
</style>
