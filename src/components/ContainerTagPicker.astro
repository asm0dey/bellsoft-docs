---
// Interactive tag picker for bellsoft/liberica-runtime-container.
// Data parsed from Docker Hub's tag list (src/data/container-tags.json):
// dimensions for the controls + the set of real, pullable bare-major tags
// used to tell the reader whether their chosen combination is published.
import data from '../data/container-tags.json';

const TYPE_LABELS = {
  'jdk-all': 'Full JDK',
  jdk: 'JDK Lite',
  jre: 'JRE',
};
const FLAG_LABELS = {
  crac: 'CRaC',
  cds: 'Class Data Sharing (CDS)',
  slim: 'Slim',
  stream: 'Stream (rolling updates)',
};
---

<figure
  class="tag-picker"
  data-repo={data.repo}
  data-tags={JSON.stringify(data.canonicalTags)}
>
  <figcaption>Build your image tag</figcaption>
  <div class="tag-picker-controls">
    <label>
      <span>Image type</span>
      <select data-field="type">
        {data.imageTypes.map((t) => (
          <option value={t}>{TYPE_LABELS[t] ?? t} ({t})</option>
        ))}
      </select>
    </label>
    <label>
      <span>Java version</span>
      <select data-field="version">
        {data.javaVersions.map((v) => (
          <option value={v} selected={v === '21'}>{v}</option>
        ))}
      </select>
    </label>
    <label>
      <span>C library</span>
      <select data-field="libc">
        {data.libc.map((l) => (
          <option value={l}>{l}</option>
        ))}
      </select>
    </label>
  </div>
  <fieldset class="tag-picker-flags">
    <legend>Options</legend>
    {data.flags.map((f) => (
      <label class="tag-flag">
        <input type="checkbox" data-flag={f} /> {FLAG_LABELS[f] ?? f}
      </label>
    ))}
  </fieldset>
  <div class="tag-picker-output">
    <code class="tag-pull"></code>
    <button type="button" class="tag-copy">Copy</button>
  </div>
  <p class="tag-status" role="status"></p>
</figure>

<script>
  const root = document.querySelector('.tag-picker');
  if (root instanceof HTMLElement) {
    const repo = root.dataset.repo;
    const tagSet = new Set(JSON.parse(root.dataset.tags ?? '[]'));
    const FLAG_ORDER = ['crac', 'cds', 'slim', 'stream'];
    const field = (name) => root.querySelector(`[data-field="${name}"]`);
    const pullEl = root.querySelector('.tag-pull');
    const statusEl = root.querySelector('.tag-status');
    const copyBtn = root.querySelector('.tag-copy');

    const buildTag = () => {
      const type = field('type').value;
      const version = field('version').value;
      const libc = field('libc').value;
      const on = new Set(
        [...root.querySelectorAll('[data-flag]')]
          .filter((c) => c.checked)
          .map((c) => c.dataset.flag)
      );
      let tag = `${type}-${version}`;
      for (const f of FLAG_ORDER) if (on.has(f)) tag += `-${f}`;
      return `${tag}-${libc}`;
    };

    const update = () => {
      const tag = buildTag();
      const available = tagSet.has(tag);
      pullEl.textContent = `docker pull ${repo}:${tag}`;
      root.classList.toggle('is-unavailable', !available);
      statusEl.textContent = available
        ? '✓ This tag is published on Docker Hub.'
        : '✗ This combination is not published — try a different version or remove an option.';
    };

    root.addEventListener('change', update);
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(pullEl.textContent ?? '');
        copyBtn.textContent = 'Copied';
        setTimeout(() => (copyBtn.textContent = 'Copy'), 1200);
      } catch {
        /* clipboard unavailable */
      }
    });
    update();
  }
</script>

<style>
  .tag-picker {
    margin: 1.5rem 0;
    padding: 1.25rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    background: var(--sl-color-gray-7, var(--sl-color-black));
  }
  .tag-picker figcaption {
    font-weight: 600;
    font-size: var(--sl-text-h5);
    margin-bottom: 1rem;
  }
  .tag-picker-controls {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: 0.75rem;
    align-items: end;
  }
  .tag-picker label {
    display: flex;
    flex-direction: column;
  }
  .tag-picker label > span {
    display: block;
    font-size: var(--sl-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3);
    margin-bottom: 0.25rem;
  }
  .tag-picker select {
    width: 100%;
    box-sizing: border-box;
    padding: 0.4rem 0.5rem;
    border-radius: 0.5rem;
    background: var(--sl-color-black);
    color: var(--sl-color-white);
    border: 1px solid var(--sl-color-gray-5);
    font-size: var(--sl-text-sm);
  }
  .tag-picker-flags {
    border: none;
    padding: 0;
    margin: 1rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
  }
  .tag-picker-flags legend {
    font-size: var(--sl-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3);
    padding: 0;
    margin-bottom: 0.5rem;
  }
  .tag-flag {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: var(--sl-text-sm);
  }
  .tag-picker-output {
    display: flex;
    align-items: stretch;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }
  .tag-pull {
    flex: 1;
    padding: 0.6rem 0.75rem;
    border-radius: 0.5rem;
    background: var(--sl-color-black);
    border: 1px solid var(--sl-color-gray-5);
    font-size: var(--sl-text-code-sm, 0.85em);
    overflow-x: auto;
    white-space: nowrap;
  }
  .tag-copy {
    padding: 0 1rem;
    border-radius: 0.5rem;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    cursor: pointer;
    font-size: var(--sl-text-sm);
  }
  .tag-copy:hover {
    border-color: var(--sl-color-accent);
  }
  .tag-status {
    margin: 0.6rem 0 0;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-green-high, #4ade80);
  }
  .tag-picker.is-unavailable .tag-status {
    color: var(--sl-color-accent-high);
  }
  .tag-picker.is-unavailable .tag-pull {
    border-color: var(--sl-color-accent);
  }
</style>
