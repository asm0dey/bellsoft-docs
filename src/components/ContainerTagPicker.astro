---
// Interactive tag picker for bellsoft/liberica-runtime-container.
// Data parsed from Docker Hub's tag list (src/data/container-tags.json):
// dimensions for the controls + the set of real, pullable bare-major tags
// used to tell the reader whether their chosen combination is published.
import { Icon } from '@astrojs/starlight/components';
import data from '../data/container-tags.json';

const TYPE_LABELS = {
  'jdk-all': 'Full JDK',
  jdk: 'JDK Lite',
  jre: 'JRE',
};
const FLAG_LABELS = {
  crac: 'CRaC',
  cds: 'Class Data Sharing (CDS)',
  slim: 'Slim',
  stream: 'Stream (rolling updates)',
};
---

<figure class="tag-picker" data-repo={data.repo}>
  <figcaption>Build your image tag</figcaption>
  <div class="tag-picker-controls">
    <label>
      <span>Image type</span>
      <select data-field="type">
        {data.imageTypes.map((t) => (
          <option value={t}>{TYPE_LABELS[t] ?? t} ({t})</option>
        ))}
      </select>
    </label>
    <div class="tag-version">
      <span class="tag-version-label">Java version</span>
      <button type="button" class="tpv-current" aria-haspopup="listbox" aria-expanded="false">
        <span class="tpv-current-label">21 (latest)</span>
        <Icon name="down-caret" size="1rem" />
      </button>
      <div class="tpv-panel" hidden>
        <input
          type="text"
          class="tpv-search"
          placeholder="Search version…"
          autocomplete="off"
          spellcheck="false"
          aria-label="Search Java version"
        />
        <ul class="tpv-list" role="listbox">
          {data.javaVersions.map((m) => (
            <Fragment>
              <li class="tpv-group" data-major={m} aria-hidden="true">Java {m}</li>
              {data.versionsByMajor[m].map((v) => (
                <li
                  class="tpv-option"
                  role="option"
                  data-value={v}
                  data-major={m}
                  data-label={v === m ? `${m} (latest)` : v}
                >
                  {v === m ? `${m} (latest)` : v}
                </li>
              ))}
            </Fragment>
          ))}
        </ul>
        <p class="tpv-empty" hidden>No matching version</p>
      </div>
      <input type="hidden" data-field="version" value="21" />
    </div>
    <label>
      <span>C library</span>
      <select data-field="libc">
        {data.libc.map((l) => (
          <option value={l}>{l}</option>
        ))}
      </select>
    </label>
  </div>
  <fieldset class="tag-picker-flags">
    <legend>Options</legend>
    {data.flags.map((f) => (
      <label class="tag-flag">
        <input type="checkbox" data-flag={f} /> {FLAG_LABELS[f] ?? f}
      </label>
    ))}
  </fieldset>
  <div class="tag-picker-output">
    <code class="tag-pull"></code>
    <button type="button" class="tag-copy">Copy</button>
  </div>
  <p class="tag-status" role="status"></p>
</figure>

<script>
  const root = document.querySelector('.tag-picker');
  if (root instanceof HTMLElement) {
    const repo = root.dataset.repo;
    const FLAG_ORDER = ['crac', 'cds', 'slim', 'stream'];
    const field = (name) => root.querySelector(`[data-field="${name}"]`);
    const pullEl = root.querySelector('.tag-pull');
    const statusEl = root.querySelector('.tag-status');
    const copyBtn = root.querySelector('.tag-copy');

    // Per-major tag sets are fetched on demand (and cached) — the page only
    // ever loads the lines the reader actually inspects.
    const cache = new Map();
    const tagsForMajor = (major) => {
      if (!cache.has(major)) {
        cache.set(
          major,
          fetch(`/container-tags/${major}.json`)
            .then((r) => (r.ok ? r.json() : []))
            .then((list) => new Set(list))
            .catch(() => null)
        );
      }
      return cache.get(major);
    };

    const buildTag = () => {
      const type = field('type').value;
      const version = field('version').value;
      const libc = field('libc').value;
      const on = new Set(
        [...root.querySelectorAll('[data-flag]')]
          .filter((c) => c.checked)
          .map((c) => c.dataset.flag)
      );
      let tag = `${type}-${version}`;
      for (const f of FLAG_ORDER) if (on.has(f)) tag += `-${f}`;
      return `${tag}-${libc}`;
    };

    const update = async () => {
      const tag = buildTag();
      pullEl.textContent = `docker pull ${repo}:${tag}`;
      root.classList.remove('is-unavailable');
      statusEl.textContent = 'Checking Docker Hub…';
      const major = field('version').value.split(/[._]/)[0];
      const set = await tagsForMajor(major);
      if (buildTag() !== tag) return; // selection changed while loading
      if (set === null) {
        statusEl.textContent = '';
        return; // offline / fetch failed — don't claim anything
      }
      const available = set.has(tag);
      root.classList.toggle('is-unavailable', !available);
      statusEl.textContent = available
        ? '✓ This tag is published on Docker Hub.'
        : '✗ This combination is not published — try a different version or remove an option.';
    };

    root.addEventListener('change', update);

    // Searchable version combobox (148+ versions across major lines).
    const vroot = root.querySelector('.tag-version');
    const vbtn = vroot.querySelector('.tpv-current');
    const vlabel = vroot.querySelector('.tpv-current-label');
    const vpanel = vroot.querySelector('.tpv-panel');
    const vsearch = vroot.querySelector('.tpv-search');
    const vlist = vroot.querySelector('.tpv-list');
    const vempty = vroot.querySelector('.tpv-empty');
    const vhidden = vroot.querySelector('[data-field="version"]');
    const voptions = [...vroot.querySelectorAll('.tpv-option')];
    const vgroups = [...vroot.querySelectorAll('.tpv-group')];

    const vSetOpen = (open) => {
      vpanel.hidden = !open;
      vbtn.setAttribute('aria-expanded', String(open));
      if (open) {
        vsearch.value = '';
        vFilter('');
        vsearch.focus();
      }
    };
    const vFilter = (q) => {
      const needle = q.trim().toLowerCase();
      for (const li of voptions) {
        li.hidden = !li.dataset.value.toLowerCase().includes(needle);
      }
      let anyVisible = false;
      for (const g of vgroups) {
        const visible = voptions.some(
          (o) => o.dataset.major === g.dataset.major && !o.hidden
        );
        g.hidden = !visible;
        if (visible) anyVisible = true;
      }
      vempty.hidden = anyVisible;
    };
    const vChoose = (li) => {
      vhidden.value = li.dataset.value;
      vlabel.textContent = li.dataset.label;
      vSetOpen(false);
      update();
    };

    vbtn.addEventListener('click', () => vSetOpen(vpanel.hidden));
    vsearch.addEventListener('input', () => vFilter(vsearch.value));
    vlist.addEventListener('click', (event) => {
      const li = event.target.closest('.tpv-option');
      if (li) vChoose(li);
    });
    vsearch.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        const first = voptions.find((o) => !o.hidden);
        if (first) vChoose(first);
      } else if (event.key === 'Escape') {
        vSetOpen(false);
        vbtn.focus();
      }
    });
    document.addEventListener('click', (event) => {
      if (!vroot.contains(event.target)) vSetOpen(false);
    });

    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(pullEl.textContent ?? '');
        copyBtn.textContent = 'Copied';
        setTimeout(() => (copyBtn.textContent = 'Copy'), 1200);
      } catch {
        /* clipboard unavailable */
      }
    });
    update();
  }
</script>

<style>
  .tag-picker {
    margin: 1.5rem 0;
    padding: 1.25rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    background: var(--sl-color-gray-7, var(--sl-color-black));
  }
  .tag-picker figcaption {
    font-weight: 600;
    font-size: var(--sl-text-h5);
    margin-bottom: 1rem;
  }
  .tag-picker-controls {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: 0.75rem;
    align-items: end;
  }
  .tag-picker label {
    display: flex;
    flex-direction: column;
  }
  .tag-picker label > span {
    display: block;
    font-size: var(--sl-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3);
    margin-bottom: 0.25rem;
  }
  .tag-picker select {
    width: 100%;
    box-sizing: border-box;
    padding: 0.4rem 0.5rem;
    border-radius: 0.5rem;
    background: var(--sl-color-black);
    color: var(--sl-color-white);
    border: 1px solid var(--sl-color-gray-5);
    font-size: var(--sl-text-sm);
  }
  .tag-version {
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .tag-version-label {
    display: block;
    font-size: var(--sl-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3);
    margin-bottom: 0.25rem;
  }
  .tpv-current {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    width: 100%;
    padding: 0.4rem 0.5rem;
    border-radius: 0.5rem;
    background: var(--sl-color-black);
    color: var(--sl-color-white);
    border: 1px solid var(--sl-color-gray-5);
    font-size: var(--sl-text-sm);
    cursor: pointer;
  }
  .tpv-current:hover,
  .tpv-current[aria-expanded='true'] {
    border-color: var(--sl-color-accent);
  }
  .tpv-panel {
    position: absolute;
    z-index: 20;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: 0.25rem;
    padding: 0.4rem;
    background: var(--sl-color-black);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);
  }
  .tpv-panel[hidden] {
    display: none;
  }
  .tpv-search {
    width: 100%;
    box-sizing: border-box;
    padding: 0.35rem 0.5rem;
    margin-bottom: 0.4rem;
    border-radius: 0.375rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    border: 1px solid var(--sl-color-gray-5);
    font-size: var(--sl-text-sm);
  }
  .tpv-search:focus {
    outline: none;
    border-color: var(--sl-color-accent);
  }
  .tpv-list {
    list-style: none;
    margin: 0;
    padding: 0;
    max-height: 16rem;
    overflow-y: auto;
  }
  .tpv-group {
    padding: 0.4rem 0.5rem 0.2rem;
    font-size: var(--sl-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-4);
  }
  .tpv-group[hidden] {
    display: none;
  }
  .tpv-option {
    padding: 0.3rem 0.5rem 0.3rem 1rem;
    border-radius: 0.375rem;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-2);
    cursor: pointer;
  }
  .tpv-option:hover {
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
  }
  .tpv-option[hidden] {
    display: none;
  }
  .tpv-empty {
    margin: 0;
    padding: 0.35rem 0.5rem;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-gray-4);
  }
  .tpv-empty[hidden] {
    display: none;
  }
  .tag-picker-flags {
    border: none;
    padding: 0;
    margin: 1rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
  }
  .tag-picker-flags legend {
    font-size: var(--sl-text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3);
    padding: 0;
    margin-bottom: 0.5rem;
  }
  .tag-flag {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: var(--sl-text-sm);
  }
  .tag-picker-output {
    display: flex;
    align-items: stretch;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }
  .tag-pull {
    flex: 1;
    padding: 0.6rem 0.75rem;
    border-radius: 0.5rem;
    background: var(--sl-color-black);
    border: 1px solid var(--sl-color-gray-5);
    font-size: var(--sl-text-code-sm, 0.85em);
    overflow-x: auto;
    white-space: nowrap;
  }
  .tag-copy {
    padding: 0 1rem;
    border-radius: 0.5rem;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    cursor: pointer;
    font-size: var(--sl-text-sm);
  }
  .tag-copy:hover {
    border-color: var(--sl-color-accent);
  }
  .tag-status {
    margin: 0.6rem 0 0;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-green-high, #4ade80);
  }
  .tag-picker.is-unavailable .tag-status {
    color: var(--sl-color-accent-high);
  }
  .tag-picker.is-unavailable .tag-pull {
    border-color: var(--sl-color-accent);
  }
</style>
