---
// Unified interactive tag picker for BellSoft container images.
//
// Two modes, ONE implementation:
//  - mode="standard" (default): bellsoft/liberica-runtime-container. Dimensions
//    come from src/data/container-tags.json; the chosen combination is validated
//    against the published bare-major tag sets in public/container-tags/<major>.json.
//  - mode="hardened": one or more hardened repos (subset of src/data/hardened-tags.json,
//    optionally narrowed by the `repos` prop). Each repo's facets render their own
//    control group; the chosen combination is resolved against the published entries
//    in public/hardened-tags/<key>.json.
//
// Every form control is rendered in this Astro template at build time (NOT via
// runtime innerHTML) so Astro's scoped <style> applies to all of them. In hardened
// mode each repo's control group is rendered up front and toggled with `hidden`.
import { Icon } from '@astrojs/starlight/components';
import standardData from '../data/container-tags.json';
import hardenedIndex from '../data/hardened-tags.json';
import distroIndex from '../data/distro-tags.json';
// NIK published entries, imported at build time so the NIK version control can be
// rendered in the template (its values are derived from the entries, not facets).
import nikTags from '../../public/hardened-tags/hardened-liberica-native-image-kit-container.json';

interface Props {
  mode?: 'standard' | 'hardened' | 'distro';
  repos?: string;
}
const { mode = 'standard', repos } = Astro.props;

const TYPE_LABELS: Record<string, string> = {
  'jdk-all': 'Full JDK',
  jdk: 'JDK Lite',
  jre: 'JRE',
};
// Hardened uses a shorter "JDK" label for the `jdk` type than standard's "JDK Lite".
const HARDENED_TYPE_LABELS: Record<string, string> = {
  'jdk-all': 'Full JDK',
  jdk: 'JDK',
  jre: 'JRE',
};
const FLAG_LABELS: Record<string, string> = {
  crac: 'CRaC',
  cds: 'Class Data Sharing (CDS)',
  slim: 'Slim',
  stream: 'Stream (rolling updates)',
  debug: 'Debug',
};
// Shorter labels used in hardened mode.
const HARDENED_FLAG_LABELS: Record<string, string> = {
  crac: 'CRaC',
  cds: 'CDS',
  debug: 'Debug',
};

const NIK_REPO = 'hardened-liberica-native-image-kit-container';

// ---- Hardened: build the subset and pre-derive per-repo data at build time. ----
const wanted = repos
  ? repos.split(',').map((s) => s.trim()).filter(Boolean)
  : null;
const subset =
  mode === 'hardened'
    ? (wanted
        ? hardenedIndex.repos.filter((r) => wanted.includes(r.key))
        : hardenedIndex.repos)
    : [];

// NIK versions are derived from the repo's published entries (imported above) so
// the searchable NIK control is rendered in the template, not built at runtime.
const nikVersions = [
  ...new Set((nikTags.entries || []).map((e: any) => e.nikVersion).filter(Boolean)),
].sort((a, b) =>
  (b as string).localeCompare(a as string, undefined, {
    numeric: true,
    sensitivity: 'base',
  })
) as string[];

const hardenedRepos = subset.map((r) => ({
  ...r,
  nikVersions: r.key === NIK_REPO ? nikVersions : [],
}));

// ---- Distro: classic liberica-openjdk-*/openjre-* images, one repo per base
// distro. Like hardened, each repo's facets render their own control group up
// front and are toggled with `hidden`. ----
const distroRepos = mode === 'distro' ? distroIndex.repos : [];
---

{mode === 'standard' && (
  <figure class="tag-picker" data-mode="standard" data-repo={standardData.repo}>
    <figcaption>Build your image tag</figcaption>
    <div class="tag-picker-controls" data-controls>
      <label>
        <span>Image type</span>
        <select data-field="type">
          {standardData.imageTypes.map((t) => (
            <option value={t}>{TYPE_LABELS[t] ?? t} ({t})</option>
          ))}
        </select>
      </label>
      <div class="tag-version" data-tpv="version">
        <span class="tag-version-label">Java version</span>
        <button type="button" class="tpv-current" aria-haspopup="listbox" aria-expanded="false">
          <span class="tpv-current-label">21 (latest)</span>
          <Icon name="down-caret" size="1rem" />
        </button>
        <div class="tpv-panel" hidden>
          <input
            type="text"
            class="tpv-search"
            placeholder="Search version…"
            autocomplete="off"
            spellcheck="false"
            aria-label="Search Java version"
          />
          <ul class="tpv-list" role="listbox">
            {standardData.javaVersions.map((m) => (
              <Fragment>
                <li class="tpv-group" data-major={m} aria-hidden="true">Java {m}</li>
                {standardData.versionsByMajor[m].map((v) => (
                  <li
                    class="tpv-option"
                    role="option"
                    data-value={v}
                    data-major={m}
                    data-label={v === m ? `${m} (latest)` : v}
                  >
                    {v === m ? `${m} (latest)` : v}
                  </li>
                ))}
              </Fragment>
            ))}
          </ul>
          <p class="tpv-empty" hidden>No matching version</p>
        </div>
        <input type="hidden" data-field="version" value="21" />
      </div>
      <label>
        <span>C library</span>
        <select data-field="libc">
          {standardData.libc.map((l) => (
            <option value={l}>{l}</option>
          ))}
        </select>
      </label>
    </div>
    <fieldset class="tag-picker-flags" data-flags>
      <legend>Options</legend>
      {standardData.flags.map((f) => (
        <label class="tag-flag">
          <input type="checkbox" data-flag={f} /> {FLAG_LABELS[f] ?? f}
        </label>
      ))}
    </fieldset>
    <div class="tag-picker-output">
      <code class="tag-pull"></code>
      <button type="button" class="tag-copy">Copy</button>
    </div>
    <p class="tag-status" role="status"></p>
  </figure>
)}

{mode === 'hardened' && hardenedRepos.length > 0 && (
  <figure class="tag-picker" data-mode="hardened">
    <figcaption>Build your image tag</figcaption>

    {hardenedRepos.length > 1 && (
      <label class="tag-repo-label">
        <span>Image</span>
        <select data-field="repo">
          {hardenedRepos.map((r) => (
            <option value={r.key}>{r.label}</option>
          ))}
        </select>
      </label>
    )}

    {hardenedRepos.map((r, ri) => {
      const f = r.facets || {};
      const versions = f.versions || [];
      const variants = f.variant || [];
      const variantDef = variants.includes('standard') ? 'standard' : variants[0];
      return (
        <div
          class="tag-repo-group"
          data-repo-group={r.key}
          data-repo={r.repo}
          hidden={ri !== 0}
        >
          <div class="tag-picker-controls" data-controls>
            {f.type && f.type.length > 0 && (
              <label>
                <span>Image type</span>
                <select data-field="type">
                  {f.type.map((t) => (
                    <option value={t}>{HARDENED_TYPE_LABELS[t] ?? t} ({t})</option>
                  ))}
                </select>
              </label>
            )}

            {versions.length > 0 && (
              <div class="tag-version" data-tpv="version">
                <span class="tag-version-label">Version</span>
                <button type="button" class="tpv-current" aria-haspopup="listbox" aria-expanded="false">
                  <span class="tpv-current-label">{versions[0]} (latest)</span>
                  <Icon name="down-caret" size="1rem" />
                </button>
                <div class="tpv-panel" hidden>
                  <input
                    type="text"
                    class="tpv-search"
                    placeholder="Search version…"
                    autocomplete="off"
                    spellcheck="false"
                    aria-label="Search version"
                  />
                  <ul class="tpv-list" role="listbox">
                    {versions.map((v, i) => (
                      <li
                        class="tpv-option"
                        role="option"
                        data-value={v}
                        data-label={i === 0 ? `${v} (latest)` : v}
                      >
                        {i === 0 ? `${v} (latest)` : v}
                      </li>
                    ))}
                  </ul>
                  <p class="tpv-empty" hidden>No matching version</p>
                </div>
                <input type="hidden" data-field="version" value={versions[0]} />
              </div>
            )}

            {r.key === NIK_REPO && r.nikVersions.length > 0 && (
              <div class="tag-version" data-tpv="nikVersion">
                <span class="tag-version-label">NIK version</span>
                <button type="button" class="tpv-current" aria-haspopup="listbox" aria-expanded="false">
                  <span class="tpv-current-label">{r.nikVersions[0]} (latest)</span>
                  <Icon name="down-caret" size="1rem" />
                </button>
                <div class="tpv-panel" hidden>
                  <input
                    type="text"
                    class="tpv-search"
                    placeholder="Search NIK version…"
                    autocomplete="off"
                    spellcheck="false"
                    aria-label="Search NIK version"
                  />
                  <ul class="tpv-list" role="listbox">
                    {r.nikVersions.map((v, i) => (
                      <li
                        class="tpv-option"
                        role="option"
                        data-value={v}
                        data-label={i === 0 ? `${v} (latest)` : v}
                      >
                        {i === 0 ? `${v} (latest)` : v}
                      </li>
                    ))}
                  </ul>
                  <p class="tpv-empty" hidden>No matching NIK version</p>
                </div>
                <input type="hidden" data-field="nikVersion" value={r.nikVersions[0]} />
              </div>
            )}

            {variants.length > 0 && (
              <label>
                <span>Variant</span>
                <select data-field="variant">
                  {variants.map((v) => (
                    <option value={v} selected={v === variantDef}>{v}</option>
                  ))}
                </select>
              </label>
            )}

            {f.libc && f.libc.length > 0 && (
              <label>
                <span>C library</span>
                <select data-field="libc">
                  {f.libc.map((l) => (
                    <option value={l}>{l}</option>
                  ))}
                </select>
              </label>
            )}
          </div>

          <fieldset class="tag-picker-flags" data-flags hidden={!(f.flags && f.flags.length > 0)}>
            <legend>Options</legend>
            {(f.flags || []).map((fl) => (
              <label class="tag-flag">
                <input type="checkbox" data-flag={fl} /> {HARDENED_FLAG_LABELS[fl] ?? fl}
              </label>
            ))}
          </fieldset>
        </div>
      );
    })}

    <div class="tag-picker-output">
      <code class="tag-pull"></code>
      <button type="button" class="tag-copy">Copy</button>
    </div>
    <p class="tag-status" role="status"></p>
  </figure>
)}

{mode === 'distro' && distroRepos.length > 0 && (
  <figure class="tag-picker" data-mode="distro">
    <figcaption>Build your image tag</figcaption>

    <label class="tag-repo-label">
      <span>Image</span>
      <select data-field="repo">
        {distroRepos.map((r) => (
          <option value={r.key}>{r.label}</option>
        ))}
      </select>
    </label>

    {distroRepos.map((r, ri) => {
      const f = r.facets || {};
      const versions = f.versions || [];
      const archs = f.archs || [];
      return (
        <div
          class="tag-repo-group"
          data-repo-group={r.key}
          data-repo={r.repo}
          hidden={ri !== 0}
        >
          <div class="tag-picker-controls" data-controls>
            {versions.length > 0 && (
              <div class="tag-version" data-tpv="version">
                <span class="tag-version-label">Version</span>
                <button type="button" class="tpv-current" aria-haspopup="listbox" aria-expanded="false">
                  <span class="tpv-current-label">{versions[0]}</span>
                  <Icon name="down-caret" size="1rem" />
                </button>
                <div class="tpv-panel" hidden>
                  <input
                    type="text"
                    class="tpv-search"
                    placeholder="Search version…"
                    autocomplete="off"
                    spellcheck="false"
                    aria-label="Search version"
                  />
                  <ul class="tpv-list" role="listbox">
                    {versions.map((v) => (
                      <li
                        class="tpv-option"
                        role="option"
                        data-value={v}
                        data-label={v}
                      >
                        {v}
                      </li>
                    ))}
                  </ul>
                  <p class="tpv-empty" hidden>No matching version</p>
                </div>
                <input type="hidden" data-field="version" value={versions[0]} />
              </div>
            )}

            {archs.length > 0 && (
              <label>
                <span>Architecture</span>
                <select data-field="arch">
                  <option value="">Any</option>
                  {archs.map((a) => (
                    <option value={a}>{a}</option>
                  ))}
                </select>
              </label>
            )}
          </div>

          <fieldset class="tag-picker-flags" data-flags hidden={!f.cds}>
            <legend>Options</legend>
            {f.cds && (
              <label class="tag-flag">
                <input type="checkbox" data-flag="cds" /> CDS
              </label>
            )}
          </fieldset>
        </div>
      );
    })}

    <div class="tag-picker-output">
      <code class="tag-pull"></code>
      <button type="button" class="tag-copy">Copy</button>
    </div>
    <p class="tag-status" role="status"></p>
  </figure>
)}

<script>
  import { withBase } from '../lib/swapVersion.mjs';

  // Standard tag assembly order (flags slot between version and libc).
  const STD_FLAG_ORDER = ['crac', 'cds', 'slim', 'stream'];
  // Hardened best-effort assembly order for flags.
  const HARD_FLAG_ORDER = ['cds', 'crac', 'debug'];

  document.querySelectorAll('.tag-picker').forEach((root) => {
    if (!(root instanceof HTMLElement)) return;
    const mode = root.dataset.mode;

    const pullEl = root.querySelector('.tag-pull');
    const statusEl = root.querySelector('.tag-status');
    const copyBtn = root.querySelector('.tag-copy');

    // ---- Shared: searchable version combobox. ----
    // Works for both the grouped (standard) and flat (hardened) option lists:
    // groups are only present in standard, so the group-toggling is guarded.
    const wireTpv = (vroot, onChoose) => {
      const vbtn = vroot.querySelector('.tpv-current');
      const vlabel = vroot.querySelector('.tpv-current-label');
      const vpanel = vroot.querySelector('.tpv-panel');
      const vsearch = vroot.querySelector('.tpv-search');
      const vlist = vroot.querySelector('.tpv-list');
      const vempty = vroot.querySelector('.tpv-empty');
      const vhidden = vroot.querySelector('input[data-field]');
      const voptions = [...vroot.querySelectorAll('.tpv-option')];
      const vgroups = [...vroot.querySelectorAll('.tpv-group')];

      const vFilter = (q) => {
        const needle = q.trim().toLowerCase();
        for (const li of voptions) {
          li.hidden = !li.dataset.value.toLowerCase().includes(needle);
        }
        if (vgroups.length) {
          let anyVisible = false;
          for (const g of vgroups) {
            const visible = voptions.some(
              (o) => o.dataset.major === g.dataset.major && !o.hidden
            );
            g.hidden = !visible;
            if (visible) anyVisible = true;
          }
          vempty.hidden = anyVisible;
        } else {
          vempty.hidden = voptions.some((o) => !o.hidden);
        }
      };
      const vSetOpen = (open) => {
        vpanel.hidden = !open;
        vbtn.setAttribute('aria-expanded', String(open));
        if (open) {
          vsearch.value = '';
          vFilter('');
          vsearch.focus();
        }
      };
      const vChoose = (li) => {
        vhidden.value = li.dataset.value;
        vlabel.textContent = li.dataset.label;
        vSetOpen(false);
        onChoose();
      };

      vbtn.addEventListener('click', () => vSetOpen(vpanel.hidden));
      vsearch.addEventListener('input', () => vFilter(vsearch.value));
      vlist.addEventListener('click', (event) => {
        const li = event.target.closest('.tpv-option');
        if (li) vChoose(li);
      });
      vsearch.addEventListener('keydown', (event) => {
        if (event.key === 'Enter') {
          const first = voptions.find((o) => !o.hidden);
          if (first) vChoose(first);
        } else if (event.key === 'Escape') {
          vSetOpen(false);
          vbtn.focus();
        }
      });
      document.addEventListener('click', (event) => {
        if (!vroot.contains(event.target)) vSetOpen(false);
      });
    };

    // ---- Shared: copy the `docker pull …` line. ----
    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(pullEl.textContent ?? '');
          copyBtn.textContent = 'Copied';
          setTimeout(() => (copyBtn.textContent = 'Copy'), 1200);
        } catch {
          /* clipboard unavailable */
        }
      });
    }

    // Per-major (standard) / per-repo (hardened) data fetched on demand + cached.
    const cache = new Map();

    if (mode === 'standard') {
      const repo = root.dataset.repo;
      const field = (name) => root.querySelector(`[data-field="${name}"]`);

      const tagsForMajor = (major) => {
        if (!cache.has(major)) {
          cache.set(
            major,
            fetch(withBase(`/container-tags/${major}.json`, import.meta.env.BASE_URL))
              .then((r) => (r.ok ? r.json() : []))
              .then((list) => new Set(list))
              .catch(() => null)
          );
        }
        return cache.get(major);
      };

      const buildTag = () => {
        const type = field('type').value;
        const version = field('version').value;
        const libc = field('libc').value;
        const on = new Set(
          [...root.querySelectorAll('[data-flag]')]
            .filter((c) => c.checked)
            .map((c) => c.dataset.flag)
        );
        let tag = `${type}-${version}`;
        for (const f of STD_FLAG_ORDER) if (on.has(f)) tag += `-${f}`;
        return `${tag}-${libc}`;
      };

      const update = async () => {
        const tag = buildTag();
        pullEl.textContent = `docker pull ${repo}:${tag}`;
        root.classList.remove('is-unavailable');
        statusEl.textContent = 'Checking Docker Hub…';
        const major = field('version').value.split(/[._]/)[0];
        const set = await tagsForMajor(major);
        if (buildTag() !== tag) return; // selection changed while loading
        if (set === null) {
          statusEl.textContent = '';
          return; // offline / fetch failed — don't claim anything
        }
        const available = set.has(tag);
        root.classList.toggle('is-unavailable', !available);
        statusEl.textContent = available
          ? '✓ This tag is published on Docker Hub.'
          : '✗ This combination is not published — try a different version or remove an option.';
      };

      root.addEventListener('change', update);
      const vroot = root.querySelector('[data-tpv="version"]');
      if (vroot) wireTpv(vroot, update);
      update();
    } else if (mode === 'hardened') {
      const repoSelect = root.querySelector('[data-field="repo"]');
      const groups = [...root.querySelectorAll('[data-repo-group]')];
      const byKey = new Map(groups.map((g) => [g.dataset.repoGroup, g]));
      let activeKey = groups[0]?.dataset.repoGroup;

      const entriesFor = (key) => {
        if (!cache.has(key)) {
          cache.set(
            key,
            fetch(withBase(`/hardened-tags/${key}.json`, import.meta.env.BASE_URL))
              .then((r) => (r.ok ? r.json() : null))
              .then((d) => (d && d.entries) || null)
              .catch(() => null)
          );
        }
        return cache.get(key);
      };

      const activeGroup = () => byKey.get(activeKey);
      const fieldVal = (name) => {
        const el = activeGroup().querySelector(`[data-field="${name}"]`);
        return el ? el.value : null;
      };
      const hasControl = (name) =>
        !!activeGroup().querySelector(`[data-field="${name}"]`);

      const update = async () => {
        const group = activeGroup();
        const repo = group.dataset.repo;
        const type = fieldVal('type');
        const version = fieldVal('version');
        const nikVersion = fieldVal('nikVersion');
        const variant = fieldVal('variant');
        const libc = fieldVal('libc');
        const checked = new Set(
          [...group.querySelectorAll('[data-flag]')]
            .filter((c) => c.checked)
            .map((c) => c.dataset.flag)
        );
        const reqKey = activeKey;

        statusEl.textContent = 'Checking Docker Hub…';
        const entries = await entriesFor(activeKey);
        if (reqKey !== activeKey) return; // repo changed while loading
        if (entries === null) {
          pullEl.textContent = '';
          statusEl.textContent = '';
          return; // offline / fetch failed — don't claim anything
        }

        const match = entries.find((e) => {
          if (hasControl('type') && e.type !== type) return false;
          if (hasControl('version') && e.version !== version) return false;
          if (hasControl('nikVersion') && e.nikVersion !== nikVersion) return false;
          if (hasControl('variant') && e.variant !== variant) return false;
          if (hasControl('libc') && e.libc !== libc) return false;
          const fl = e.flags || [];
          if (fl.length !== checked.size) return false;
          for (const f of fl) if (!checked.has(f)) return false;
          return true;
        });

        if (match) {
          pullEl.textContent = `docker pull ${repo}:${match.tag}`;
          root.classList.remove('is-unavailable');
          statusEl.textContent = '✓ This tag is published on Docker Hub.';
          return;
        }

        // Best-effort assembled tag (omit "standard" variant and empty parts).
        const parts = [];
        if (hasControl('type') && type) parts.push(type);
        if (hasControl('version') && version) parts.push(version);
        if (hasControl('nikVersion') && nikVersion) parts.push(`nik-${nikVersion}`);
        for (const f of HARD_FLAG_ORDER) if (checked.has(f)) parts.push(f);
        if (hasControl('variant') && variant && variant !== 'standard') parts.push(variant);
        if (hasControl('libc') && libc) parts.push(libc);
        const assembled = parts.join('-') || 'latest';
        pullEl.textContent = `docker pull ${repo}:${assembled}`;
        root.classList.add('is-unavailable');
        statusEl.textContent =
          '✗ This combination is not published — try a different selection.';
      };

      // Wire each repo group's comboboxes once (markup already exists).
      for (const group of groups) {
        group.querySelectorAll('[data-tpv]').forEach((vroot) => wireTpv(vroot, update));
      }

      const showActive = () => {
        for (const group of groups) {
          group.hidden = group.dataset.repoGroup !== activeKey;
        }
      };

      root.addEventListener('change', (event) => {
        if (repoSelect && event.target === repoSelect) return; // handled below
        update();
      });

      if (repoSelect) {
        repoSelect.addEventListener('change', () => {
          activeKey = repoSelect.value;
          showActive();
          update();
        });
      }

      showActive();
      update();
    } else if (mode === 'distro') {
      const repoSelect = root.querySelector('[data-field="repo"]');
      const groups = [...root.querySelectorAll('[data-repo-group]')];
      const byKey = new Map(groups.map((g) => [g.dataset.repoGroup, g]));
      let activeKey = groups[0]?.dataset.repoGroup;

      const entriesFor = (key) => {
        if (!cache.has(key)) {
          cache.set(
            key,
            fetch(withBase(`/distro-tags/${key}.json`, import.meta.env.BASE_URL))
              .then((r) => (r.ok ? r.json() : null))
              .then((d) => (d && d.entries) || null)
              .catch(() => null)
          );
        }
        return cache.get(key);
      };

      const activeGroup = () => byKey.get(activeKey);
      const fieldVal = (name) => {
        const el = activeGroup().querySelector(`[data-field="${name}"]`);
        return el ? el.value : null;
      };
      const hasControl = (name) =>
        !!activeGroup().querySelector(`[data-field="${name}"]`);

      const update = async () => {
        const group = activeGroup();
        const repo = group.dataset.repo;
        const version = fieldVal('version');
        const arch = fieldVal('arch'); // "" means Any (matches null), or null if no control
        const cds = !!group.querySelector('[data-flag="cds"]:checked');
        const reqKey = activeKey;

        statusEl.textContent = 'Checking Docker Hub…';
        const entries = await entriesFor(activeKey);
        if (reqKey !== activeKey) return; // repo changed while loading
        if (entries === null) {
          pullEl.textContent = '';
          statusEl.textContent = '';
          return; // offline / fetch failed — don't claim anything
        }

        const archChosen = hasControl('arch') && arch !== '';
        const match = entries.find((e) => {
          if (e.version !== version) return false;
          if (archChosen ? e.arch !== arch : e.arch !== null) return false;
          if (e.cds !== cds) return false;
          return true;
        });

        if (match) {
          pullEl.textContent = `docker pull ${repo}:${match.tag}`;
          root.classList.remove('is-unavailable');
          statusEl.textContent = '✓ This tag is published on Docker Hub.';
          return;
        }

        // Best-effort assembled tag.
        let assembled = version || 'latest';
        if (cds) assembled += '-cds';
        if (archChosen) assembled += `-${arch}`;
        pullEl.textContent = `docker pull ${repo}:${assembled}`;
        root.classList.add('is-unavailable');
        statusEl.textContent =
          '✗ This combination is not published — try a different selection.';
      };

      // Wire each repo group's comboboxes once (markup already exists).
      for (const group of groups) {
        group.querySelectorAll('[data-tpv]').forEach((vroot) => wireTpv(vroot, update));
      }

      const showActive = () => {
        for (const group of groups) {
          group.hidden = group.dataset.repoGroup !== activeKey;
        }
      };

      root.addEventListener('change', (event) => {
        if (repoSelect && event.target === repoSelect) return; // handled below
        update();
      });

      if (repoSelect) {
        repoSelect.addEventListener('change', () => {
          activeKey = repoSelect.value;
          showActive();
          update();
        });
      }

      showActive();
      update();
    }
  });
</script>

